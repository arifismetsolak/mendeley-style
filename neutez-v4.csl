<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" class="in-text" version="1.0" default-locale="tr-TR">
  <info>
    <title>NEÜ Tıp Tezi - Yazar Yıl v4</title>
    <id>http://www.zotero.org/styles/neu-tip-tezi-yazar-yil-v4</id>
    <link href="http://www.zotero.org/styles/neu-tip-tezi-yazar-yil-v4" rel="self"/>
    <author>
      <name>OpenAI</name>
    </author>
    <category citation-format="author-date"/>
    <category field="medicine"/>
    <summary>NEÜ tıp tezlerinde kullanılan parantez içi yazar-yıl atıfı ve alfabetik, numarasız kaynakça biçimi.</summary>
    <updated>2026-07-18T00:00:00+00:00</updated>
    <rights license="http://creativecommons.org/licenses/by-sa/3.0/">Creative Commons Attribution-ShareAlike 3.0 License</rights>
  </info>

  <locale xml:lang="tr">
    <terms>
      <term name="and">ve</term>
      <term name="et-al">et al.</term>
      <term name="and others">ve ark.</term>
      <term name="editor" form="short">ed.</term>
      <term name="page" form="short">s.</term>
      <term name="edition" form="short">baskı</term>
      <term name="accessed">Erişim tarihi:</term>
    </terms>
  </locale>

  <macro name="author-citation">
    <names variable="author" delimiter=", ">
      <name form="short" and="text" delimiter-precedes-last="never" initialize-with=""/>
      <et-al term="and others"/>
      <substitute>
        <names variable="editor"/>
        <text variable="title" form="short"/>
      </substitute>
    </names>
  </macro>

  <macro name="author-bibliography">
    <names variable="author" delimiter=", ">
      <name name-as-sort-order="all" sort-separator=" " initialize-with="" delimiter=", " and="text" delimiter-precedes-last="never"/>
      <substitute>
        <names variable="editor"/>
        <text variable="title"/>
      </substitute>
    </names>
  </macro>

  <macro name="issued-year">
    <date variable="issued">
      <date-part name="year"/>
    </date>
  </macro>

  <macro name="title">
    <text variable="title"/>
  </macro>

  <macro name="container">
    <text variable="container-title" form="short"/>
  </macro>

  <macro name="publisher">
    <group delimiter=": ">
      <text variable="publisher-place"/>
      <text variable="publisher"/>
    </group>
  </macro>

  <macro name="access">
    <choose>
      <if variable="URL">
        <group delimiter=" ">
          <text variable="URL"/>
          <group prefix="(" suffix=")" delimiter=" ">
            <text term="accessed"/>
            <date variable="accessed" form="text"/>
          </group>
        </group>
      </if>
    </choose>
  </macro>

  <citation disambiguate-add-year-suffix="true" collapse="year-suffix" et-al-min="3" et-al-use-first="1">
    <sort>
      <key variable="issued" sort="ascending"/>
      <key macro="author-citation" sort="ascending"/>
    </sort>
    <layout prefix="(" suffix=")" delimiter="; ">
      <group delimiter=" ">
        <text macro="author-citation"/>
        <text macro="issued-year"/>
      </group>
    </layout>
  </citation>

  <bibliography hanging-indent="false" et-al-min="6" et-al-use-first="5" entry-spacing="0" line-spacing="1">
    <sort>
      <key macro="author-bibliography"/>
      <key macro="issued-year"/>
      <key variable="title"/>
    </sort>
    <layout suffix=".">
      <text macro="author-bibliography" suffix=". "/>
      <choose>
        <if type="article-journal article-magazine article-newspaper" match="any">
          <text macro="title" suffix=". "/>
          <text macro="container" suffix=". "/>
          <text macro="issued-year"/>
          <group prefix=";" delimiter="">
            <text variable="volume"/>
            <text variable="issue" prefix="(" suffix=")"/>
          </group>
          <text variable="page" prefix=":"/>
        </if>
        <else-if type="chapter paper-conference entry-dictionary entry-encyclopedia" match="any">
          <text macro="title" suffix=". "/>
          <text term="in" text-case="capitalize-first" suffix=": "/>
          <names variable="editor" suffix=", ">
            <name initialize-with="" delimiter=", " and="text"/>
            <label form="short" prefix=", "/>
          </names>
          <text variable="container-title" suffix=". "/>
          <text variable="edition" suffix=". baskı. "/>
          <text macro="publisher" suffix="; "/>
          <text macro="issued-year"/>
          <text variable="page" prefix=". s. "/>
        </else-if>
        <else-if type="thesis">
          <text macro="title"/>
          <text variable="genre" prefix=" [" suffix="]"/>
          <text value=". "/>
          <text macro="publisher" suffix="; "/>
          <text macro="issued-year"/>
        </else-if>
        <else-if type="webpage post-weblog" match="any">
          <text macro="title" suffix=". "/>
          <text macro="issued-year" suffix=". "/>
          <text macro="access"/>
        </else-if>
        <else>
          <text macro="title" suffix=". "/>
          <text variable="edition" suffix=". baskı. "/>
          <text macro="publisher" suffix="; "/>
          <text macro="issued-year"/>
          <text macro="access" prefix=". "/>
        </else>
      </choose>
    </layout>
  </bibliography>
</style>
